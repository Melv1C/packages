{
  "name": "@melv1c/packages",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "release:prepare": "npx changeset",
    "release:publish": "./scripts/release.sh",
    "knip": "bunx knip",
    "deps": "bunx npm-check-updates",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "deps:interactive": "bunx npm-check-updates -i"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.8.16"
  },
  "packageManager": "bun@1.3.10"
}
