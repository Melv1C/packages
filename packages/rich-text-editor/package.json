{
  "name": "@melv1c/rich-text-editor",
  "version": "0.0.0",
  "description": "A rich text editor component for React, built with TipTap and styled with Tailwind CSS.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Melv1C/packages.git#main"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.0",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "lucide-react": "^0.513.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.20.3",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@melv1c/ui-core": ">=1.1.0",
    "react": ">=19",
    "react-dom": ">=19",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0"
  }
}
